{
  "name": "react-rendercov",
  "version": "0.4.0",
  "description": "generate render coverage for react components using playwright",
  "keywords": [
    "playwright",
    "react",
    "react-render-coverage",
    "fiber",
    "internals"
  ],
  "bugs": {
    "url": "https://github.com/sidakram/react-rendercov/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sidakram/react-rendercov.git"
  },
  "license": "MIT",
  "author": {
    "name": "Mohammad Akram",
    "email": "markadm.dev@gmail.com"
  },
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./playwright": {
      "types": "./dist/playwright.d.mts",
      "import": "./dist/playwright.mjs",
      "default": "./dist/playwright.mjs"
    }
  },
  "files": [
    "dist",
    "bin",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "publint": "npx publint",
    "build": "NODE_ENV=production tsdown",
    "dev": "NODE_ENV=development tsdown --watch"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@swc/core": "^1.10.15",
    "@types/node": "^22.20.1",
    "publint": "^0.3.4",
    "tsdown": "^0.22.4",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "bippy": "^0.5.43"
  },
  "peerDependencies": {
    "@playwright/test": "^1.45",
    "react": ">=17.0.1",
    "react-dom": ">=17.0.1"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  }
}
