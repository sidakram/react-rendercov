{
  "name": "@react-rendercov/monorepo",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "publint:rcov": "turbo run publint --filter=react-rendercov",
    "build": "turbo run build",
    "build:rcov": "turbo run build --filter=react-rendercov",
    "lint": "biome lint --write",
    "format": "biome format --write",
    "check": "biome check --write",
    "sherif": "sherif --fix",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@9.8.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "sherif": "^1.3.0",
    "turbo": "^2.4.2"
  },
  "allowScripts": {
    "@biomejs/biome@1.9.4": true,
    "@swc/core@1.15.43": true,
    "esbuild@0.21.5": true,
    "fsevents@2.3.3": true
  }
}
